---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";
---

<Layout title={`免责声明 | ${SITE.title}`}>
  <Header />
  <Main pageTitle="免责声明" pageDesc="请在使用本博客提供的教程和内容前仔细阅读以下免责声明。">
    <div class="app-prose max-w-app prose-img:border-0 mt-8 mb-28">
      <h2>1. 信息准确性</h2>
      <p>
        本博客（以下简称“本站”）旨在分享 Sing-box 等网络代理技术的相关教程、经验和技术心得。所有文章仅代表作者个人观点，由于技术本身的快速迭代以及网络环境的复杂性，本站不能保证所提供内容的绝对准确性、时效性或完整性。使用者因依赖本站信息而导致的直接或间接损失，本站概不负责。
      </p>

      <h2>2. 合法合规使用</h2>
      <p>
        本站提供的所有教程、配置信息和脚本仅供学习、研究和交流使用。
        <strong>强烈提醒：</strong>任何用户在使用本站提供的技术知识时，均应严格遵守所在国家或地区的法律法规。切勿将相关技术用于任何非法用途（包括但不限于访问被当地法律禁止的受限内容、实施网络攻击或侵犯他人合法权益等）。由此引发的一切法律责任由使用者自行承担。
      </p>

      <h2>3. 外部链接</h2>
      <p>
        本站文章中可能包含指向其他外部网站的链接（涉及 GitHub 项目、第三方服务等）。这些外部链接仅为方便读者提供参考，并不代表本站认可其内容。本站对这些外部网站或服务的真实性、安全性和合法性不做任何保证，请自行甄别风险。
      </p>

      <h2>4. 内容修改与解释权</h2>
      <p>
        本站有权在无需事先通知的情况下随时修改、更新或删除任何内容。本免责声明的最终解释权归本站站长所有。如您继续访问并使用本站，即视为您同意本免责声明的全部内容。
      </p>
    </div>
  </Main>
  <Footer />
</Layout>
