---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";

// Data
const friends = [
  {
    name: "Sing-box 官方文档",
    desc: "最权威的官方接口文档和路由示例，支持最前沿协议特性的风向标。",
    url: "https://sing-box.sagernet.org/",
    avatar: "https://avatars.githubusercontent.com/u/105658622?s=200&v=4",
  },
  {
    name: "Astro 官方框架",
    desc: "本站驱动核心：构建终极性能与零 JS 静态页面的现代 Web 前端框架。",
    url: "https://astro.build/",
    avatar: "https://astro.build/favicon.svg",
  },
  {
    name: "Cloudflare 开发者",
    desc: "全球最大 CDN 与边缘计算服务商提供文档中心与免费建站服务指引。",
    url: "https://developers.cloudflare.com/",
    avatar: "https://www.cloudflare.com/favicon.ico",
  },
  {
    name: "Docker Hub",
    desc: "海量容器镜像的源泉，自建 Homelab 与软路由环境的最佳起步区。",
    url: "https://hub.docker.com/",
    avatar: "https://www.docker.com/favicon.ico",
  }
];
---

<Layout title="友情链接 | Sing-box 教程指南">
  <Header />

  <main id="main-content" class="relative app-layout pb-12 pt-8">
    <div class="mb-4">
      <BackButton />
    </div>
    
    <div class="mb-8 flex items-center gap-3">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl text-foreground">
        友情链接
      </h1>
      <div class="h-px flex-1 bg-border/20 mt-2" />
    </div>

    <p class="mb-10 text-foreground/80 leading-relaxed text-lg">
      这里收集了一些非常硬核且极具干货的技术博客、工具官网与资源站。排名不分先后。<br/>
      如果你也有致力于独立开发、网关工程或折腾分享类型的站点，欢迎通过 GitHub 或是邮箱联系我互换友链。
    </p>

    <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-2">
      {
        friends.map((friend) => (
          <li class="card-glow group/card relative flex items-center gap-5 rounded-2xl border border-border/25 p-5 transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:bg-accent/5 hover:shadow-lg hover:shadow-accent/10">
            <!-- Glow & noise background element as in Card component -->
            <div class="card-glow-effect pointer-events-none absolute inset-0 z-0 rounded-2xl opacity-0 transition-opacity duration-300 group-hover/card:opacity-100" />
            <div class="card-noise pointer-events-none absolute inset-0 z-1 rounded-2xl opacity-0 transition-opacity duration-300 group-hover/card:opacity-100" />

            <!-- avatar -->
            <div class="relative z-10 flex size-16 shrink-0 items-center justify-center overflow-hidden rounded-full border border-border/30 bg-muted/20 sm:size-20">
              <img src={friend.avatar} alt={friend.name} class="h-full w-full object-cover" loading="lazy" />
            </div>
            
            <!-- content -->
            <div class="relative z-10 flex flex-col justify-center">
              <a href={friend.url} target="_blank" rel="noopener noreferrer nofollow" class="text-lg sm:text-xl font-bold tracking-tight text-foreground transition-colors group-hover/card:text-accent focus-visible:outline-none">
                {friend.name}
                <span class="absolute inset-0 z-20" aria-hidden="true" />
              </a>
              <p class="mt-1 line-clamp-3 text-sm leading-snug opacity-70">
                {friend.desc}
              </p>
            </div>
          </li>
        ))
      }
    </ul>
  </main>
  <Footer />
</Layout>

<style>
  .card-glow-effect {
    background: radial-gradient(
      350px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      color-mix(in oklab, var(--accent) 8%, transparent) 0%,
      color-mix(in oklab, var(--accent) 6%, transparent) 15%,
      color-mix(in oklab, var(--accent) 4%, transparent) 30%,
      color-mix(in oklab, var(--accent) 2%, transparent) 45%,
      color-mix(in oklab, var(--accent) 0.8%, transparent) 60%,
      transparent 80%
    );
    transform: translateZ(0);
    will-change: transform;
  }
  .card-noise {
    background-image: url("/noise.png");
    background-repeat: repeat;
    background-size: 64px 64px;
    mix-blend-mode: overlay;
    opacity: 0;
  }
  .group\/card:hover .card-noise {
    opacity: 0.4;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLElement>(".card-glow").forEach(card => {
      card.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty("--mouse-x", `${e.clientX - rect.left}px`);
        card.style.setProperty("--mouse-y", `${e.clientY - rect.top}px`);
      });
    });
  });
</script>
