---
// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

// if breadcrumb is Home > Posts > 1 <etc>
// replace Posts with Posts (page number)
const i18nMap: Record<string, string> = {
  posts: "教程",
  tags: "标签",
  about: "关于作者",
  search: "搜索",
  archives: "归档",
  galleries: "图集",
  basics: "基础入门",
  server: "服务器搭建",
  advanced: "规则进阶",
  clients: "客户端",
  geek: "极客探索",
  routing: "路由分流",
  config: "配置详解",
  convert: "配置转换",
  protocols: "新协议",
  friends: "友情链接",
};

// if breadcrumb is Home > Posts > 1 <etc>
// replace Posts with Posts (page number)
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(0, 2, `教程 (第 ${breadcrumbList[1] || 1} 页)`);
}

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  const tagName = i18nMap[breadcrumbList[1]] || decodeURIComponent(breadcrumbList[1]);
  breadcrumbList.splice(
    1,
    3,
    `${tagName} ${Number(breadcrumbList[2]) === 1 ? "" : "(第 " + breadcrumbList[2] + " 页)"}`
  );
}
---

<nav class="app-layout mt-6 mb-2" aria-label="breadcrumb">
  <div class="breadcrumb-bar inline-flex items-center gap-1.5 rounded-full border border-border/20 bg-muted/5 px-3 py-1.5 font-cartograph text-sm backdrop-blur-sm">
    {/* Home icon / Root symbol */}
    <a
      href="/"
      class="breadcrumb-link inline-flex shrink-0 items-center justify-center rounded-md px-1.5 py-0.5 text-foreground/50 transition-colors duration-200 hover:bg-muted/10 hover:text-accent"
      aria-label="首页"
      title="首页"
    >
      ~
    </a>
    {
      breadcrumbList.map((breadcrumb, index) => {
        const decoded = decodeURIComponent(breadcrumb);
        const translated = i18nMap[decoded.toLowerCase()] || decoded;
        
        return (
        <>
          <span
            class="breadcrumb-sep shrink-0 text-accent/40"
            aria-hidden="true"
          >
            /
          </span>

          {index + 1 === breadcrumbList.length ? (
            <span
              class:list={[
                "breadcrumb-current truncate px-1.5 py-0.5 text-accent/90 capitalize"
              ]}
              aria-current="page"
            >
              {translated}
            </span>
          ) : (
            <a
              href={`/${breadcrumb}/`}
              class="breadcrumb-link shrink-0 rounded-md px-1.5 py-0.5 capitalize text-foreground/50 transition-colors duration-200 hover:bg-muted/10 hover:text-accent"
            >
              {translated}
            </a>
          )}
        </>
      )})
    }
  </div>
</nav>

<style>
  .breadcrumb-bar {
    -webkit-backdrop-filter: blur(4px);
  }

  .breadcrumb-current {
    max-width: 28ch;
  }
</style>
