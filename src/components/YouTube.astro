---
export interface Props {
  id: string;
  title?: string;
}

const { id, title = "YouTube Video Player" } = Astro.props;
---

<div class="relative w-full overflow-hidden rounded-xl my-8 aspect-video shadow-lg bg-skin-card">
  {/* 使用 youtube-nocookie 提升隐私保护，并添加 loading="lazy" 提升网页核心网页指标 (Core Web Vitals) 的 SEO 表现 */}
  <iframe
    class="absolute top-0 left-0 w-full h-full border-0"
    src={`https://www.youtube-nocookie.com/embed/${id}`}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>
